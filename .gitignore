# Rust workspace build artefacts.  We commit Cargo.lock so the
# CI / replay paths use a pinned dependency graph.
/target/
crates/*/target/

# P4.1+P4.2: PyO3 wrapper crate's post-build import symlinks.
# `crates/dlcp-sim-py/build.sh` creates these after every
# `cargo build --release` to make `import dlcp_sim_native`
# resolvable two ways:
#   * `crates/dlcp-sim-py/dlcp_sim_native.so` -- import from
#     the crate dir (P4.1 verify path).
#   * `src/dlcp_sim_native.so` -- import via PYTHONPATH=src
#     (project-standard incantation; P4.2's verify path
#     and the `src/dlcp_fw/sim/dlcp_sim_native.py` facade).
# Both symlinks point at `target/release/libdlcp_sim_native.{
# dylib,so}` (target/ is already ignored above) and are
# regenerated on every cargo build, so we don't track them.
crates/dlcp-sim-py/dlcp_sim_native.so
src/dlcp_sim_native.so

sim_artifacts/
tmp_gpsim_lcd_capture/
*.stage*.hex

# Generated annotated disassembly
*.annotated.asm

# MPLAB X project folders generated alongside firmware images
firmware/**/*.X/

# Local preset captures and metadata
LX521.4_22MG10F-v5.bin
LX521.4_22MG10F-v5.json
LX521.4_22MG10F-v7.bin
LX521.4_22MG10F-v7.json
preset_b.bin
preset_b.json

# Local assembler/build byproducts
firmware/patched/releases/*.cod
src/dlcp_fw/asm/*.cod
src/dlcp_fw/asm/*.hex
src/dlcp_fw/asm/*.lst

# Local baked preset release artifacts
firmware/patched/releases/*_presetA.hex
firmware/patched/releases/*_presetA.manifest.json

# Local converted reference text dumps
firmware/reference/*.txt

# Per-checkout state file written by .claude/hooks/codex-review-on-commit.sh
# (records the last HEAD hash that triggered a codex review reminder so the
# hook doesn't re-fire on amends or unrelated git invocations).
.claude/.codex-last-reviewed-head

# cargo-fuzz auto-generated state (P5b.1 fuzz target).  The fuzz target
# itself is committed at `crates/dlcp-sim/fuzz/{Cargo.toml,
# fuzz_targets/}`, but the corpus / artifacts / Cargo.lock are
# operator-local (corpus = libFuzzer's accumulated input dictionary,
# artifacts = crash repros, Cargo.lock = pinned-by-nightly).
crates/dlcp-sim/fuzz/Cargo.lock
crates/dlcp-sim/fuzz/corpus/
crates/dlcp-sim/fuzz/artifacts/
