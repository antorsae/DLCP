# Rust workspace build artefacts.  We commit Cargo.lock so the
# CI / replay paths use a pinned dependency graph.
/target/
crates/*/target/

# P4.1: PyO3 wrapper crate's post-build import symlink.
# `crates/dlcp-sim-py/build.sh` creates this after every
# `cargo build --release` to make `python -c "import
# dlcp_sim_native"` work from the crate directory.  The
# symlink target lives under `target/` (already ignored)
# and the symlink itself shouldn't be tracked.
crates/dlcp-sim-py/dlcp_sim_native.so

sim_artifacts/
tmp_gpsim_lcd_capture/
*.stage*.hex

# Generated annotated disassembly
*.annotated.asm

# MPLAB X project folders generated alongside firmware images
firmware/**/*.X/

# Local preset captures and metadata
LX521.4_22MG10F-v5.bin
LX521.4_22MG10F-v5.json
LX521.4_22MG10F-v7.bin
LX521.4_22MG10F-v7.json
preset_b.bin
preset_b.json

# Local assembler/build byproducts
firmware/patched/releases/*.cod
src/dlcp_fw/asm/*.cod
src/dlcp_fw/asm/*.hex
src/dlcp_fw/asm/*.lst

# Local baked preset release artifacts
firmware/patched/releases/*_presetA.hex
firmware/patched/releases/*_presetA.manifest.json

# Local converted reference text dumps
firmware/reference/*.txt

# Per-checkout state file written by .claude/hooks/codex-review-on-commit.sh
# (records the last HEAD hash that triggered a codex review reminder so the
# hook doesn't re-fire on amends or unrelated git invocations).
.claude/.codex-last-reviewed-head
