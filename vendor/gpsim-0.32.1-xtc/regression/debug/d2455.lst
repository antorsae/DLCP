                                           ;
                                           ;  Interrupt Vector
                                           ;
                                           ;------------------------------------------------------------------------


                                           HI_PRI   CODE    0x008               ; interrupt vector location
000008   d008     bra     0x00001a         	bra     hi_pri_isr

                                           LO_PRI   CODE    0x018               ; interrupt vector location
000018   0000     nop                      	nop
                                           hi_pri_isr:
00001a   6f60     movwf   0x60, 0x1                movwf   w_temp
00001c   cfd8     movff   0xfd8, 0x061             movff   STATUS,status_temp
00001e   f061
000020   cfe0     movff   0xfe0, 0x062             movff   BSR,bsr_temp
000022   f062
                                           	



                                           check_TMR0_interrupt:


                                               ;;==================
                                               ;; TMR3 Interrupt
                                               ;;==================

000024   b4f2     btfsc   0xf2, 0x2, 0x0   	BTFSC	INTCON,T0IF		;If the roll over flag is not set
000026   aaf2     btfss   0xf2, 0x5, 0x0   	 BTFSS	INTCON,T0IE		;or the interrupt is not enabled
000028   d002     bra     0x00002e         	  bra   checkTMR0IntEnd         ;

                                               ;; TMR0 has rolled over. Clear the pending interrupt and notify
                                               ;; the foreground code by incrementing the "roll over" counter
                                               ;; Notice that the increment operation is atomic - this means
                                               ;; we won't have to worry about the foreground code and interrupt
                                               ;; code clashing over accesses to this variable.
                                           	
00002a   94f2     bcf     0xf2, 0x2, 0x0           BCF     INTCON,T0IF,0           ; Clear the pending interrupt
00002c   2b64     incf    0x64, 0x1, 0x1           INCF    TMR0_RollOver,F         ; Set a flag to indicate rollover

                                           checkTMR0IntEnd:

                                               ;;==================
                                               ;; TMR3 Interrupt
                                               ;;==================
00002e   b2a1     btfsc   0xa1, 0x1, 0x0   	BTFSC	PIR2,TMR3IF
000030   a2a0     btfss   0xa0, 0x1, 0x0   	 BTFSS	PIE2,TMR3IE
000032   d007     bra     0x000042         	  BRA	checkTMR3IntEnd

000034   92a1     bcf     0xa1, 0x1, 0x0   	BCF	PIR2,TMR3IF		;Clear the interrupt
000036   2b65     incf    0x65, 0x1, 0x1   	INCF	TMR3_RollOver,F		;Set a flag
000038   8eb3     bsf     0xb3, 0x7, 0x0   	BSF     TMR3H, 7     		; Preload for 1 sec overflow

                                              ; Note, since we have a 32768 Hz crystal tied to TMR3 and we have the timer
                                              ; configured as a 16-bit timer TMR3H loaded with 0x80, then this interrupt 
                                              ; will happen once every second.

00003a   4b6a     infsnz  0x6a, 0x1, 0x1   	INFSNZ	SecondsLo,F		;Update the system time.
00003c   2b6b     incf    0x6b, 0x1, 0x1   	 INCF	SecondsHi,F


00003e   6b68     clrf    0x68, 0x1        	CLRF	TMR3H_Sampled
000040   6b69     clrf    0x69, 0x1        	CLRF	TMR3H_Last
                                           checkTMR3IntEnd:

                                           ExitInterrupt:
000042   c062     movff   0x062, 0xfe0     	MOVFF  bsr_temp, BSR        ; Restore BSR
000044   ffe0
000046   5160     movf    0x60, 0x0, 0x1   	MOVF   w_temp, W            ; Restore WREG
000048   c061     movff   0x061, 0xfd8     	MOVFF  status_temp, STATUS  ; Restore STATUS
00004a   ffd8

00004c   0011     retfie  0x1              	RETFIE	1

                                           MAIN	CODE

                                           Start:	

                                             ;------------------------------------------------------------------------
                                             ;
                                             ; Embedded simulation scripts
                                             ;
                                             ; Set the clock frequency to 10MHz

                                             .sim "frequency 10e6"


                                             ; define a stimulus to generate a 32kHz clock. This will be tied
                                             ; to TMR3's input and is used to simulate an external drive.
                                             ;
                                             ; 40MHz 
                                             ;   Instruction Rate = (4 clks/instruction) / (10e6 clks/second)
                                             ;                    = 400nS per instruction
                                             ;  32.768kHz ==> 30.517uS period
                                             ;  Instruction Cycles/32.768kHz cycle = 30.517uS / .4uS 
                                             ;                                     = 76.2925 instructions
                                             ;

                                             .sim "stimulus asynchronous_stimulus "
                                             .sim "initial_state 0"
                                             .sim "start_cycle 0x2008130"
                                           ;  .sim "start_cycle 0x0008130"
                                             .sim "period 305"
                                             .sim "{ 38,1 ,  76,0 , 114,1 , 152,0 , 190,1 , 228,0 , 266,1}"
                                             .sim "name Clk32kHz"
                                             .sim "end"

                                             ; Create a node

                                             .sim "node clk_node"

                                             ; attach the clock

                                             .sim "attach clk_node  Clk32kHz portc0"



                                             ; At reset, all bits of t1Con should be clear.
                                             .assert "t1con == 0x00"
00004e   0000     nop                      	nop
                                             .assert "t3con == 0x00"
000050   0000     nop                      	nop

000052   0e03     movlw   0x03             	MOVLW	(1<<RC0)|(1<<RC1)  ;The lower two bits of PORTC are for
000054   1294     iorwf   0x94, 0x1, 0x0   	IORWF	TRISC,F		   ;the 32kHz oscillator and should be inputs

                                           	; Load TMR3H, TMR3L with 0x8000 for one second interupts
000056   6ab2     clrf    0xb2, 0x0        	CLRF	TMR3L
000058   0e80     movlw   0x80             	MOVLW	0x80
00005a   6eb3     movwf   0xb3, 0x0        	MOVWF	TMR3H

00005c   92a1     bcf     0xa1, 0x1, 0x0   	BCF	PIR2,TMR3IF	;Clear any TMR3 pending interrupt
00005e   82a0     bsf     0xa0, 0x1, 0x0   	BSF	PIE2,TMR3IE	;Enable TMR3 interrupts
000060   8cf2     bsf     0xf2, 0x6, 0x0   	BSF	INTCON,PEIE	;Enable Peripheral interrupts
000062   8ef2     bsf     0xf2, 0x7, 0x0   	BSF	INTCON,GIE	;Enable Global interrupts

                                             ; TMR3 not running yet, TMR3H and TMR3L should be unchanged
000064   50b2     movf    0xb2, 0x0, 0x0   	MOVF	TMR3L,W		; test read
                                              .assert "W==0, '*** FAILED 18f2455 TMR3 test TMR3L read'"
000066   0000     nop                      	nop
000068   50b3     movf    0xb3, 0x0, 0x0   	MOVF	TMR3H,W
                                              .assert "W==0x80, '*** FAILED 18f2455 TMR3 test TMR3H read'"
00006a   0000     nop                      	nop

                                           ;	goto test3

                                             ; Simulate crystal oscillator for TMR1 external source
                                             ;
00006c   0e09     movlw   0x09             	MOVLW	( (1<<T1OSCEN) | (1<<TMR1ON) )
00006e   6ecd     movwf   0xcd, 0x0        	MOVWF	T1CON
000070   0e03     movlw   0x03                     MOVLW   (1<<TMR3CS) | (1<<TMR3ON)
                                                   ;MOVLW   (1<<TMR3ON)
000072   6eb1     movwf   0xb1, 0x0                MOVWF	T3CON

                                           	; Delay 16,793,733 about 6.7 seconds with TMR3 counting seconds
000074   6b66     clrf    0x66, 0x1        	clrf	countLo
000076   0e10     movlw   0x10             	MOVLW	0x10
000078   6f67     movwf   0x67, 0x1        	MOVWF	countHi
00007a   0004     clrwdt                   L1:	clrwdt
00007c   d827     rcall   0x0000cc         	rcall	d1
