                                                   ;; tmr3_18f2455.asm
                                                   ;;
                                                   ;; The purpose of this program is to test how well gpsim can simulate
                                                   ;; TMR1 for a 18f2455 pic (like the 18fxxx family) although
                                           	;; most of the functionality is generic to all processors where
                                           	;; t1mer1 supports an external clock source.
                                           	;;
                                                   ;; Here are the tests performed:
                                           	;;
                                           	;; -- TMR3 count seconds when driven by simulated external crystal
                                           	;; -- TMR3 driven Fosc/4 with prescale of 8
                                           	;; -- TMR3 count seconds when driven by external stimuli
                                           	;; -- TMR3L and TMR3H can be read and written

                                           	list    p=18f2455                ; list directive to define processor
                                           	include <p18f2455.inc>
                                                   LIST

                                           ;==========================================================================
                                           ; Build date : Oct 21 2015
                                           ;  MPASM PIC18F2455 processor include
                                           ; 
                                           ;  (c) Copyright 1999-2015 Microchip Technology, All rights reserved
                                           ;==========================================================================

                                                   NOLIST
                                                   include <coff.inc>              ; Grab some useful macros
                                             list
                                           ; coff.inc - gputils header file
                                             nolist
                                                   radix   dec                     ; Numbers are assumed to be decimal



                                           ;----------------------------------------------------------------------

                                           ; Printf Command
                                           .command macro x
                                             .direct "C", x
                                             endm

                                           ;----------------------------------------------------------------------
                                           GPR_DATA                UDATA
                                           w_temp          RES     1
                                           status_temp     RES     1
                                           bsr_temp        RES     1
                                           failures        RES     1

                                           TMR0_RollOver	RES	1
                                           TMR3_RollOver	RES	1
                                           countLo		RES	1
                                           countHi		RES	1
                                           TMR3H_Sampled	RES	1
                                           TMR3H_Last	RES	1
                                           SecondsLo	RES	1
                                           SecondsHi	RES	1

                                             GLOBAL countLo, countHi
                                             GLOBAL SecondsLo, SecondsHi

                                           ;----------------------------------------------------------------------
                                           ;   ******************* MAIN CODE START LOCATION  ******************
                                           ;----------------------------------------------------------------------
                                           STARTUP    CODE	0

000000   d026     bra     0x00004e         	bra	Start


