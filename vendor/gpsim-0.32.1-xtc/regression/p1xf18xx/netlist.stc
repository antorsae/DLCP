
# This file was written by gpsim.

# You can use this file for example like this:
#     gpsim -s mycode.cod -c netlist.stc

# If you want to add commands, you can create another .stc file
# and load this file from it. Something like this:
# ----------- myproject.stc ---------------
# load s mycode.cod
# frequency 12000000
# load c netlist.stc
# -----------------------------------------
# You can then just load this new file:
#     gpsim -c myproject.stc
# and use netlist.stc whenever you save from the breadboard.
#


# Processor position:
module library libgpsim_modules


# Modules:
p12f1822.BreakOnReset = true
p12f1822.SafeMode = true
p12f1822.UnknownMode = true
p12f1822.WarnMode = true
p12f1822.tmr1_freq = 32768
p12f1822.xpos = 72
p12f1822.ypos = 72

module load usart U2
U2.rxbaud = 9600
U2.txbaud = 9600
U2.xpos = 72
U2.ypos = 192



# Connections:
node PIC_tx


node PIC_rx


node PIC_tx2
attach PIC_tx2 porta0 RXPIN

node PIC_rx2
attach PIC_rx2 porta5 TXPIN



# End.
