
# This file was written by gpsim.

# You can use this file for example like this:
#     gpsim -s mycode.cod -c netlist.stc

# If you want to add commands, you can create another .stc file
# and load this file from it. Something like this:
# ----------- myproject.stc ---------------
# load s mycode.cod
# frequency 12000000
# load c netlist.stc
# -----------------------------------------
# You can then just load this new file:
#     gpsim -c myproject.stc
# and use netlist.stc whenever you save from the breadboard.
#


# Processor position:
module library libgpsim_modules


# Modules:
p16f88.BreakOnReset = true
p16f88.SafeMode = true
p16f88.UnknownMode = true
p16f88.WarnMode = true
p16f88.tmr1_freq = 32768
p16f88.xpos = 72
p16f88.ypos = 156

module load usart U1
U1.rxbaud = 9600
U1.txbaud = 9600
U1.xpos = 72
U1.ypos = 72



# Connections:
node PIC_tx
attach PIC_tx p16f88.portb5 U1.RXPIN

node PIC_rx
attach PIC_rx p16f88.portb2 U1.TXPIN



# End.
