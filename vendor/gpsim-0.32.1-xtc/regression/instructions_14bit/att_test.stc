load instructions_14bit.cod 
module library libgpsim_modules
module load usart U1
node n1                  # define a node
node n2                  #define another node
symbol TWO=2             #define symbol with value 2
attach n1 pin(1) pin(TWO) #attach CPU pins 1 and 2
attach n1 U1.RXPIN       #add usart pin to n1
attach n2 portb0 pin(U1.TXPIN)
node
