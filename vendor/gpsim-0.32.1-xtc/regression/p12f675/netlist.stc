
# This file was written by gpsim.

# You can use this file for example like this:
#     gpsim -s mycode.cod -c netlist.stc

# If you want to add commands, you can create another .stc file
# and load this file from it. Something like this:
# ----------- myproject.stc ---------------
# load s mycode.cod
# frequency 12000000
# load c netlist.stc
# -----------------------------------------
# You can then just load this new file:
#     gpsim -c myproject.stc
# and use netlist.stc whenever you save from the breadboard.
#

# Processor position:
module library libgpsim_modules

# Modules:
p12f683.BreakOnReset = true
p12f683.SafeMode = true
p12f683.UnknownMode = true
p12f683.WarnMode = true
p12f683.xpos = 84
p12f683.ypos = 60

module load pullup pullup
pullup.capacitance = 0
pullup.resistance = 10000
pullup.voltage = 5
pullup.xpos = 216
pullup.ypos = 36

module load pulldown pulldown
pulldown.capacitance = 0
pulldown.resistance = 10000
pulldown.voltage = 0
pulldown.xpos = 216
pulldown.ypos = 96

module load led leda7
leda7.ActiveState = high
leda7.color = green
leda7.xpos = 300
leda7.ypos = 60

module load ttl595 sr0
sr0.xpos = 348
sr0.ypos = 24

node ledconn
#attach ledconn p12f683.gpio2 leda7.in sr0.Ds
attach ledconn p12f683.gpio0 leda7.in sr0.Ds

node vcc
attach vcc pullup.pin sr0.MR

node gnd
attach gnd pulldown.pin sr0.OE

node zSCK
attach zSCK p12f683.gpio5 sr0.SCK

node zRCK
attach zRCK p12f683.gpio4 sr0.RCK

# End.
