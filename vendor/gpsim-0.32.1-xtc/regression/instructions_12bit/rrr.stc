load test.cod

# Processor position:
module library libgpsim_modules


# Modules:
p10f202.BreakOnReset = true
p10f202.SafeMode = true
p10f202.UnknownMode = true
p10f202.WarnMode = true
p10f202.xpos = 300
p10f202.ypos = 132

module load pullup pu
pu.capacitance = 0
pu.resistance = 10000
pu.voltage = 5
pu.xpos = 324
pu.ypos = 660

module load pulldown pd
pd.capacitance = 0
pd.resistance = 0
pd.voltage = 5
pd.xpos = 456
pd.ypos = 660

module load ttl595 sr0
sr0.xpos = 108
sr0.ypos = 84

module load led leda0
leda0.ActiveState = high
leda0.color = red
