ledb7.xpos = 648
ledb7.ypos = 36


# Connections:
node vcc
attach vcc pu.pin sr0.MR sr1.MR

node gnd
attach gnd pd.pin sr0.OE sr1.OE

node gp0
attach gp0 gpio0 sr0.RCK sr1.RCK

node gp1
attach gp1 gpio1 sr0.SCK sr1.SCK

node gp2
attach gp2 gpio2 sr0.Ds

node daisy01
attach daisy01 sr0.Qs sr1.Ds

node gp3
attach gp3 gpio3

node sr0q0
attach sr0q0 sr0.Q0 leda0.in

node sr0q1
attach sr0q1 sr0.Q1 leda1.in

node sr0q2
attach sr0q2 sr0.Q2 leda2.in

node sr0q3
attach sr0q3 sr0.Q3 leda3.in

node sr0q4
attach sr0q4 sr0.Q4 leda4.in

node sr0q5
attach sr0q5 sr0.Q5 leda5.in

