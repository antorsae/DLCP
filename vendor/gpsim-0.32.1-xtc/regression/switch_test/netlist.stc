# Processor position:
module library libgpsim_modules


# Modules:
processor  U1
U1.BreakOnReset = true
U1.SafeMode = true
U1.UnknownMode = true
U1.WarnMode = true
U1.xpos = 72
U1.ypos = 72

module load switch SW1
SW1.Rclosed = 10
SW1.Ropen = 1e+08
SW1.state = false
SW1.xpos = 216
SW1.ypos = 156

module load pullup PU1
PU1.capacitance = 2e-07
PU1.resistance = 1e+08
PU1.voltage = 5
PU1.xpos = 204
PU1.ypos = 36

module load pulldown PD1
PD1.capacitance = 4e-06
PD1.resistance = 5000
PD1.voltage = 5
PD1.xpos = 204
PD1.ypos = 96

module load switch SW2
SW2.Rclosed = 10
SW2.Ropen = 1e+06
SW2.state = false
SW2.xpos = 216
SW2.ypos = 228



# Connections:
node nb0
attach nb0 SW1.A portb0 portc0 PU1.pin SW2.A

node nc0
attach nc0 SW1.B PD1.pin portc1

node nc1
attach nc1 SW2.B portc2



# End.
