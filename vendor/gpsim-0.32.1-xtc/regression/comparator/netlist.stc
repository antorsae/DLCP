# Processor position:
module library libgpsim_modules


# Modules:
p18f26k22.BreakOnReset = true
p18f26k22.SafeMode = true
p18f26k22.UnknownMode = true
p18f26k22.WarnMode = true
p18f26k22.tmr1_freq = 32768
p18f26k22.tmr3_freq = 32768
p18f26k22.tmr5_freq = 32768
p18f26k22.xpos = 72
p18f26k22.ypos = 72

module load pullup V1
V1.capacitance = 0
V1.resistance = 100
V1.voltage = 2
V1.xpos = 240
V1.ypos = 72

module load pullup V2
V2.capacitance = 0
V2.resistance = 100
V2.voltage = 2.5
V2.xpos = 84
V2.ypos = 24

module load pullup V3
V3.capacitance = 0
V3.resistance = 100
V3.voltage = 4.5
V3.xpos = 84
V3.ypos = 288

module load pullup V4
V4.capacitance = 0
V4.resistance = 100
V4.voltage = 3.5
V4.xpos = 240
V4.ypos = 120

module load pullup V5
V5.capacitance = 0
V5.resistance = 100
V5.voltage = 0
V5.xpos = 240
V5.ypos = 156

module load led c1out
c1out.ActiveState = high
c1out.color = red
c1out.xpos = 240
c1out.ypos = 264

module load led c2out
c2out.ActiveState = high
c2out.color = red
c2out.xpos = 240
c2out.ypos = 312



# Connections:
node n_cvref
attach n_cvref    

node n_vrefcon1
attach n_vrefcon1  

node na0
attach na0 V3.pin p18f26k22.porta3 p18f26k22.porta3

node na1
attach na1 V1.pin p18f26k22.porta1

node na3
attach na3 V2.pin p18f26k22.porta0 p18f26k22.porta0

node na4
attach na4 V4.pin p18f26k22.portb3

node na5
attach na5 V5.pin p18f26k22.portc0



# End.
